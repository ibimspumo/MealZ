{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MealZ",
  "version": "0.1.0",
  "identifier": "de.agentz.mealz",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MealZ",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#F4F6F1"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/recipe-media/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNzFBOTFFNkVFRkYwQTcKUldTbjhPOXVIcWx4d2U2eTEwVlYxby8ycGVwUTE4TzhqR1hETlh3Y2lTanRTUTArbnloSUdrR3kK",
      "endpoints": [
        "https://github.com/ibimspumo/MealZ/releases/latest/download/latest.json"
      ]
    }
  }
}
